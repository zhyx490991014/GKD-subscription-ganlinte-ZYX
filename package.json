{
  "name": "gkd-subscription-zhyx1996-zyx",
  "type": "module",
  "version": "2.0.66",
  "gkd": {
    "outDir": "dist",
    "file": "zhyx1996_gkd.json5",
    "versionFile": "zhyx1996_gkd.version.json5",
    "changelog": "CHANGELOG.md",
    "README.md": "README.md"
  },
  "main": "./dist/zhyx1996_gkd.json5",
  "unpkg": "./dist/zhyx1996_gkd.json5",
  "jsdelivr": "./dist/zhyx1996_gkd.json5",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "./dist"
  ],
  "scripts": {
    "postinstall": "simple-git-hooks",
    "format": "prettier --cache --write \"**/*.{js,cjs,mjs,ts,jsx,tsx,json}\"",
    "lint": "eslint --cache --fix \"src/**/*.{js,cjs,mjs,ts,jsx,tsx}\" \"scripts/**/*.{ts,tsx}\"",
    "check": "tsc --noEmit && bun run ./scripts/check.ts",
    "build": "tsc --noEmit && bun run ./scripts/build.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged",
    "commit-msg": "bunx commitlint --config commitlint.config.ts --edit ${1}",
    "pre-push": "bun run check"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts,jsx,tsx}": [
      "prettier --cache --write",
      "eslint --cache --fix"
    ],
    "*.json": [
      "prettier --cache --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@commitlint/types": "20.0.0",
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "10.0.1",
    "@gkd-kit/api": "0.8.0",
    "@gkd-kit/define": "0.0.1",
    "@gkd-kit/tools": "^0.8.0",
    "@types/bun": "latest",
    "@types/node": "25.2.3",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "esbuild": "0.27.3",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-unused-imports": "4.4.1",
    "json5": "2.2.3",
    "lint-staged": "16.2.7",
    "prettier": "3.8.1",
    "simple-git-hooks": "2.13.1",
    "typescript": "5.9.2"
  },
  "author": "zhyx1996",
  "license": "MIT",
  "homepage": "https://github.com/zhyx1996/GKD-subscription-ganlinte-ZYX#readme",
  "bugs": {
    "url": "https://github.com/zhyx1996/GKD-subscription-ganlinte-ZYX/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhyx1996/GKD-subscription-ganlinte-ZYX.git"
  },
  "packageManager": "bun@1.2.21",
  "engineStrict": true,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "picocolors": "1.1.1",
    "typescript-eslint": "^8.55.0"
  }
}
